{
  "name": "uplnk-workspace",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter uplnk dev",
    "build": "pnpm --filter uplnk build",
    "bundle-migrations": "bun scripts/bundle-migrations.ts",
    "prebuild": "bun scripts/bundle-migrations.ts",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:integration": "pnpm -r test:integration",
    "docker:build": "docker build -t uplnk .",
    "docker:run": "docker run -it -v ~/.uplnk:/home/uplnk/.uplnk uplnk"
  },
  "engines": {
    "bun": ">=1.1.30",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "react-devtools-core": "file:./stubs/react-devtools-core",
      "@aws-sdk/client-s3": "file:./stubs/aws-sdk-client-s3"
    }
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "*",
    "react-devtools-core": "*",
    "eslint-plugin-react-hooks": "^7.0.1",
    "typescript-eslint": "^8.58.1",
    "semantic-release": "^24.2.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "conventional-changelog-conventionalcommits": "^8.0.0"
  }
}

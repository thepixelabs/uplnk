# Publish workspace packages without requiring each to have a separate registry entry.
# pnpm will substitute workspace:* with the resolved version before publishing.
publish-workspace-packages=true

# Never hoist native modules — better-sqlite3 must resolve from the package that declares it.
hoist-pattern[]=!better-sqlite3

# Ensure .js extensions are written into the bundled output correctly for ESM.
node-linker=hoisted

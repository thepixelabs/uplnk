{
  "name": "uplnk",
  "version": "1.4.0",
  "description": "A terminal-native AI chat client — local-first, privacy-first",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "uplnk": "./dist/uplnk.js"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx bin/uplnk.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^0.0.50",
    "@ai-sdk/openai-compatible": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "ai": "^4.3.0",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.3.0",
    "clipboardy": "^4.0.0",
    "figlet": "^1.11.0",
    "gray-matter": "^4.0.3",
    "ink": "^5.0.0",
    "js-yaml": "^4.1.1",
    "node-record-lpcm16": "^1.0.1",
    "react": "^18.3.1",
    "ulid": "^2.3.0",
    "unzipper": "^0.12.3",
    "vosk-koffi": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@total-typescript/ts-reset": "^0.6.0",
    "@types/figlet": "^1.7.0",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.3.1",
    "@types/unzipper": "^0.10.11",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@uplnk/catalog": "workspace:*",
    "@uplnk/db": "workspace:*",
    "@uplnk/providers": "workspace:*",
    "@uplnk/shared": "workspace:*",
    "eslint": "^9.14.0",
    "husky": "^9.1.0",
    "ink-testing-library": "^4.0.0",
    "jsdom": "^29.0.2",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}

{
  "name": "uplnk-workspace",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter uplnk-dev dev",
    "build": "pnpm --filter uplnk-dev build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:integration": "pnpm -r test:integration",
    "docker:build": "docker build -t uplnk-dev .",
    "docker:run": "docker run -it -v ~/.uplnk:/home/uplnk/.uplnk uplnk-dev"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}

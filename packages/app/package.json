{
  "name": "pylon-dev",
  "version": "0.2.0",
  "description": "A terminal-native LLM developer assistant",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "pylon": "./bin/pylon.js"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx bin/pylon.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^0.0.50",
    "@ai-sdk/openai-compatible": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "@types/react": "^18.3.1",
    "ai": "^4.3.0",
    "chalk": "^5.3.0",
    "ink": "^5.0.0",
    "pylon-catalog": "workspace:*",
    "pylon-db": "workspace:*",
    "pylon-providers": "workspace:*",
    "pylon-shared": "workspace:*",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@total-typescript/ts-reset": "^0.6.0",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.14.0",
    "husky": "^9.1.0",
    "ink-testing-library": "^4.0.0",
    "jsdom": "^29.0.2",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}

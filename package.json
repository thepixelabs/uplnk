{
  "name": "uplnk-workspace",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter uplnk dev",
    "build": "pnpm --filter uplnk build",
    "bundle-migrations": "tsx scripts/bundle-migrations.ts",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:integration": "pnpm -r test:integration",
    "docker:build": "docker build -t uplnk-dev .",
    "docker:run": "docker run -it -v ~/.uplnk:/home/uplnk/.uplnk uplnk-dev"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "volta": {
    "node": "22.22.2"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "typescript-eslint": "^8.58.1",
    "semantic-release": "^24.2.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "conventional-changelog-conventionalcommits": "^8.0.0"
  }
}

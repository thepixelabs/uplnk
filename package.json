{
  "name": "pylon-workspace",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter pylon-dev dev",
    "build": "pnpm --filter pylon-dev build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:integration": "pnpm -r test:integration",
    "docker:build": "docker build -t pylon-dev .",
    "docker:run": "docker run -it -v ~/.pylon:/home/pylon/.pylon pylon-dev"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "volta": {
    "node": "22.22.2"
  }
}
